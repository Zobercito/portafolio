---
import type { NavLink } from "../types/portfolio";

const navLinks: NavLink[] = [
  { label: "Home", href: "/" },
  { label: "Sobre mí", href: "#about" },
  { label: "Experiencia", href: "#experience" },
  { label: "Contacto", href: "#contact" },
];
---

<header class="fixed top-0 inset-x-0 z-50 pointer-events-none">
  <nav class="max-w-5xl mx-auto px-2 sm:px-6 py-3 sm:py-4 min-[2000px]:py-6 flex items-center justify-center">
    <ul class="flex flex-wrap items-center justify-center gap-x-2 min-[2000px]:gap-x-6 gap-y-2 sm:gap-y-0 pointer-events-auto">
      {
        navLinks.map((link) => (
          <li>
            <a
              href={link.href}
            class="nav-link text-xs sm:text-sm min-[2000px]:text-base text-zinc-400 hover:text-zinc-100 px-2 sm:px-3 min-[2000px]:px-6 py-1.5 min-[2000px]:py-3 rounded-lg min-[2000px]:rounded-xl transition-all duration-300 tracking-wide"
            >
              {link.label}
            </a>
          </li>
        ))
      }
    </ul>
  </nav>
</header>
