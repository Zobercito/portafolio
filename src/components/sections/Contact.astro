---
import SocialButton from "../SocialButton.astro";
import PrivacyLink from "../PrivacyLink.tsx";
import { icons } from "../../data/icons";
import { ROCKET_SVG } from "../../data/rocketSvg";
import type { SocialLink } from "../../types/portfolio";

interface Props {
  socialLinks: SocialLink[];
  turnstileSitekey: string;
}

const { socialLinks, turnstileSitekey } = Astro.props;
---

<section
  id="contact"
  data-section="3"
  class="h-[100svh] xl:h-screen w-full flex flex-col justify-center px-6 sm:px-10 md:px-24 xl:px-6 max-w-5xl mx-auto"
>
  <div class="grid grid-cols-1 xl:grid-cols-2 gap-8 xl:gap-12 items-center w-full pt-8 md:pt-12 xl:pt-16">
    <!-- Left column: contact info & links -->
    <div class="md:col-span-1">
      <span class="text-zinc-500 text-sm sm:text-base tracking-widest uppercase mb-4 block">
        ¿Trabajamos juntos?
      </span>

      <h2 class="text-3xl xl:text-5xl font-bold mb-6 text-zinc-100">
        Contáctame
      </h2>

      <p class="text-zinc-400 text-sm md:text-base leading-relaxed">
        Siempre estoy abierto a nuevas oportunidades y proyectos
        interesantes. Si crees que podemos colaborar o simplemente quieres
        charlar sobre alguna idea, envíame un correo. ¡Estaré encantado de
        responder!
      </p>

      <!-- Botón mailto visible solo en móvil y tablet -->
      <div class="mt-6 xl:hidden">
        <a
          href="mailto:francisco@zobercito.dev"
          class="group inline-flex items-center gap-2 bg-zinc-100 text-zinc-900 text-sm px-6 py-3 rounded-full
                 hover:bg-zinc-200 hover:scale-105 active:scale-95
                 transition-all duration-200 font-medium"
        >
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path>
          </svg>
          Envíame un mensaje
        </a>
      </div>

      <p class="text-zinc-500 text-sm md:text-base mt-6">
        Otras formas de contactarme:
      </p>

      <div class="flex flex-wrap items-center gap-3 mt-4">
        <button
          data-copy-email
          class="group inline-flex items-center gap-2 border border-zinc-800
                 text-zinc-400 text-sm px-4 py-2 rounded-full
                 hover:border-zinc-600 hover:text-zinc-100 hover:scale-105 hover:-translate-y-0.5
                 transition-all duration-300"
        >
          <div class="relative w-5 h-5 flex-shrink-0">
            <span
              set:html={icons.copy.outline}
              class="absolute inset-0 transition-opacity duration-300 group-hover:opacity-0"
            />
            <span
              set:html={icons.copy.filled}
              class="absolute inset-0 opacity-0 transition-opacity duration-300 group-hover:opacity-100"
            />
          </div>
          <span data-copy-label>Copiar correo</span>
        </button>

        {
          socialLinks
            .filter((link) => link.label !== "email" && link.label !== "descargar cv")
            .map((link) => (
              <SocialButton
                href={link.href}
                label={link.label}
                icon={link.icon}
                iconHover={link.iconHover}
                download={link.download}
              />
            ))
        }
      </div>

      <p class="text-zinc-500 text-sm md:text-base mt-6">
        O si te interesa mi CV:
      </p>

      <div class="mt-4">
        {
          socialLinks
            .filter((link) => link.label === "descargar cv")
            .map((link) => (
              <SocialButton
                href={link.href}
                label={link.label}
                icon={link.icon}
                iconHover={link.iconHover}
                download={link.download}
              />
            ))
        }
      </div>
    </div>

    <!-- Right column: rocket + form -->
    <div class="relative w-full hidden xl:block">
      <!-- Rocket that rises from behind the bottom of the form on submit -->
      <div
        data-rocket
        aria-hidden="true"
        style="position:absolute;bottom:0;left:50%;transform:translateX(-50%) translateY(0%);opacity:0;z-index:0;pointer-events:none;transition:none;"
      >
        <div data-rocket-content style="width: 100%; height: 100%;" set:html={ROCKET_SVG} />
      </div>

      <!-- Form card sits above the rocket (z-index:1) -->
      <div
        class="relative w-full bg-zinc-900/50 border border-zinc-800/80 rounded-2xl backdrop-blur-sm p-5 sm:p-6"
        style="z-index:1;"
      >
        <form
          data-contact-form
          data-turnstile-sitekey={turnstileSitekey}
          class="space-y-4"
        >
          <div>
            <label for="contact-name" class="block text-zinc-400 text-sm mb-2">Nombre</label>
            <input
              type="text"
              id="contact-name"
              name="name"
              required
              placeholder="Tu nombre"
              class="w-full bg-zinc-950 border border-zinc-800 rounded-lg px-4 py-3 text-zinc-100 text-sm
                   placeholder:text-zinc-600 focus:outline-none focus:border-zinc-600 transition-colors"
            />
          </div>

          <div>
            <label for="contact-email" class="block text-zinc-400 text-sm mb-2">Correo</label>
            <input
              type="email"
              id="contact-email"
              name="email"
              required
              placeholder="tu@correo.com"
              class="w-full bg-zinc-950 border border-zinc-800 rounded-lg px-4 py-3 text-zinc-100 text-sm
                   placeholder:text-zinc-600 focus:outline-none focus:border-zinc-600 transition-colors"
            />
          </div>

          <div>
            <label for="contact-message" class="block text-zinc-400 text-sm mb-2">Mensaje</label>
            <textarea
              id="contact-message"
              name="message"
              required
              rows="4"
              placeholder="¿En qué puedo ayudarte?"
              class="w-full bg-zinc-950 border border-zinc-800 rounded-lg px-4 py-3 text-zinc-100 text-sm
                   placeholder:text-zinc-600 focus:outline-none focus:border-zinc-600 transition-colors
                   resize-none custom-scrollbar"
            ></textarea>
          </div>

          <!-- Cloudflare Turnstile widget -->
          <div class="flex justify-center py-0">
            <div class="cf-turnstile"></div>
          </div>

          <button
            type="submit"
            data-submit-btn
            disabled
            class="w-full bg-zinc-100 text-zinc-900 px-6 py-3 rounded-lg text-sm font-medium
                 hover:bg-zinc-200 hover:scale-[1.02] active:scale-[0.98]
                 transition-all duration-200 disabled:opacity-50 disabled:cursor-not-allowed disabled:hover:scale-100"
          >
            Completa el captcha para enviar
          </button>
        </form>
      </div>
    </div>
  </div>

  <div class="mt-8 md:mt-12 text-center pb-4">
    <PrivacyLink client:load />
  </div>
</section>
