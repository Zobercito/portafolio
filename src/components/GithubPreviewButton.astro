---
interface Props {
  href: string;
  label: string;
  icon: string;
  iconHover: string;
}

const { href, label, icon, iconHover } = Astro.props;
---

<div class="group relative inline-flex" data-github-preview-wrap>
  <a
    href={href}
    target="_blank"
    rel="noopener noreferrer"
    aria-label="Abrir perfil de GitHub"
    class="inline-flex items-center gap-2 border border-zinc-800 text-zinc-400 text-sm px-4 py-2 rounded-full hover:border-zinc-600 hover:text-zinc-100 hover:scale-105 hover:-translate-y-0.5 transition-all duration-300"
  >
    <span class="relative w-5 h-5 shrink-0">
      <span set:html={icon} class="absolute inset-0 transition-opacity duration-300 group-hover:opacity-0" />
      <span set:html={iconHover} class="absolute inset-0 opacity-0 transition-opacity duration-300 group-hover:opacity-100" />
    </span>
    {label}
  </a>

  <div
    aria-hidden="true"
    class="pointer-events-none absolute left-0 bottom-full z-20 mb-3 inline-block overflow-hidden rounded-3xl border border-zinc-800/80 bg-zinc-950/95 p-4 text-left shadow-[0_24px_80px_rgba(0,0,0,0.55)] backdrop-blur-xl opacity-0 translate-y-2 scale-95 transition duration-300 ease-out data-[open=true]:opacity-100 data-[open=true]:translate-y-0 data-[open=true]:scale-100"
    style="width: fit-content; max-width: min(28rem, calc(100vw - 3rem));"
    data-github-preview-card
    data-open="false"
  >
    <div class="absolute inset-x-0 top-0 h-px bg-linear-to-r from-transparent via-white/25 to-transparent" />

    <div class="flex items-center gap-3">
      <div class="relative shrink-0">
        <img
          src="https://github.com/Zobercito.png?size=160"
          alt="Avatar de GitHub de Francisco González"
          class="h-11 w-11 rounded-2xl border border-zinc-700 object-cover"
          loading="lazy"
        />
        <span class="absolute -bottom-1 -right-1 h-4 w-4 rounded-full border border-zinc-950 bg-emerald-400 shadow-[0_0_0_2px_rgba(16,185,129,0.15)]" />
      </div>

      <div class="min-w-0 flex-1">
        <p class="text-zinc-100 text-sm font-semibold leading-tight">Francisco</p>
        <p class="text-zinc-500 text-xs mt-0">@Zobercito</p>
      </div>
    </div>

    <p class="mt-3 text-sm leading-relaxed text-zinc-300">
      Desarrollador Fullstack. Aquí verás mis proyectos, herramientas y experimentos open‑source.
    </p>

    <div class="mt-4 flex flex-col gap-2 text-xs text-zinc-300">
      <div class="flex items-center justify-center gap-2 rounded-2xl border border-zinc-800 bg-zinc-900/70 px-3 py-1">
        <span class="w-5 h-5 text-zinc-400 shrink-0">
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z" />
            <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1 1 15 0Z" />
          </svg>
        </span>
        <span class="whitespace-nowrap text-center"><span class="text-zinc-500">Ubicación:</span> Panamá</span>
      </div>

      <div class="flex items-center gap-2 rounded-2xl border border-zinc-800 bg-zinc-900/70 px-3 py-1">
        <span class="w-5 h-5 text-zinc-400 shrink-0">
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5" />
            <path stroke-linecap="round" stroke-linejoin="round" d="M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z" />
          </svg>
        </span>
        <span class="font-mono text-zinc-400 whitespace-nowrap" data-github-local-time>--:-- (UTC --:--)</span>
      </div>
    </div>
  </div>
</div>

<script>
  const wrap = document.querySelector("[data-github-preview-wrap]") as HTMLElement | null;
  const card = document.querySelector("[data-github-preview-card]") as HTMLElement | null;
  const localTimeNode = document.querySelector("[data-github-local-time]");
  let hoverTimer: number | null = null;

  // Only enable preview behavior on devices that support hover (desktop/laptop).
  // This avoids showing the preview or running timers on touch/phone devices.
  const isDesktop = typeof window !== "undefined" && window.matchMedia('(hover: hover) and (min-width: 640px)').matches;

  const formatOffset = (date: Date) => {
    const totalMinutes = -date.getTimezoneOffset();
    const sign = totalMinutes >= 0 ? "+" : "-";
    const absoluteMinutes = Math.abs(totalMinutes);
    const hours = String(Math.floor(absoluteMinutes / 60)).padStart(2, "0");
    const minutes = String(absoluteMinutes % 60).padStart(2, "0");

    return `${sign}${hours}:${minutes}`;
  };

  const renderLocalTime = () => {
    if (!localTimeNode) return;

    const now = new Date();

    const locale: string | undefined = (typeof navigator !== "undefined" && (navigator.language || (navigator.languages && navigator.languages[0]))) || undefined;

    const dtf = new Intl.DateTimeFormat(locale, { hour: "numeric", minute: "2-digit" });

    let timeStr = dtf.format(now);

    // Try to get parts so we can normalize AM/PM to uppercase with dots (A.M. / P.M.)
    if (typeof dtf.formatToParts === "function") {
      const parts = dtf.formatToParts(now);
      const hourPart = parts.find((p) => p.type === "hour")?.value ?? "";
      const minutePart = parts.find((p) => p.type === "minute")?.value ?? "";
      const dayPeriodPart = parts.find((p) => p.type === "dayPeriod")?.value;

      if (dayPeriodPart) {
        // Normalize localized dayPeriod to A.M. / P.M. when it uses latin letters, otherwise keep as-is uppercased
        let dp = dayPeriodPart;
        const lettersOnly = dp.replace(/[^A-Za-z]/g, "");
        if (/^[APap]$/.test(lettersOnly) || /^[APap][Mm]?$/.test(lettersOnly) || /[AaPp]/.test(lettersOnly)) {
          const ch = (lettersOnly[0] || "A").toUpperCase();
          dp = `${ch}.M.`; // results in A.M. or P.M.
        } else if (lettersOnly.length >= 2 && /^[APap][Mm]?$/.test(lettersOnly)) {
          dp = lettersOnly.toUpperCase().replace(/^([AP])M?$/, "$1.M.");
        } else {
          dp = dp.toUpperCase();
        }

        timeStr = `${hourPart}:${minutePart} ${dp}`;
      } else {
        timeStr = `${hourPart}:${minutePart}`;
      }
    }

    localTimeNode.textContent = `${timeStr} (UTC ${formatOffset(now)})`;
  };

  const openCard = () => {
    if (!card) return;
    card.dataset.open = "true";
  };

  const closeCard = () => {
    if (!card) return;
    card.dataset.open = "false";
  };

  const handleMouseEnter = () => {
    if (hoverTimer) {
      window.clearTimeout(hoverTimer);
    }

    hoverTimer = window.setTimeout(() => {
      openCard();
    }, 300);
  };

  const handleMouseLeave = () => {
    if (hoverTimer) {
      window.clearTimeout(hoverTimer);
      hoverTimer = null;
    }

    closeCard();
  };

  if (isDesktop) {
    renderLocalTime();

    // Sync next update to the exact start of the next minute, then update every 60s.
    const nowSync = new Date();
    const msToNext = (60 - nowSync.getSeconds()) * 1000 - nowSync.getMilliseconds();
    let minuteInterval: number | null = null;
    let minuteTimeout: number | null = window.setTimeout(() => {
      renderLocalTime();
      minuteInterval = window.setInterval(renderLocalTime, 60_000) as unknown as number;
      minuteTimeout = null;
    }, msToNext) as unknown as number;

    if (wrap) {
      wrap.addEventListener("mouseenter", handleMouseEnter);
      wrap.addEventListener("mouseleave", handleMouseLeave);
    }

    // Clean up on page unload to avoid dangling timers (good practice)
    window.addEventListener("beforeunload", () => {
      if (minuteTimeout) window.clearTimeout(minuteTimeout as number);
      if (minuteInterval) window.clearInterval(minuteInterval as number);
      if (hoverTimer) window.clearTimeout(hoverTimer as number);
    });
  } else {
    // Ensure the preview card remains closed and inert on touch / small devices
    if (card) card.dataset.open = "false";
    if (wrap) wrap.setAttribute("data-github-preview-disabled", "true");
  }
</script>